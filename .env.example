# Copy to .env for local development (loaded automatically by python-dotenv if
# you run `flask run`, or export these in your shell). NEVER commit a real .env.

# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_CONFIG=default            # "production" enables secure cookies
FLASK_APP=app.py

# Database
# Dev (default): leave unset to use sqlite:///expense.db
# Prod (Render): DATABASE_URL=postgresql://user:pass@host:5432/dbname
# (postgres:// URLs are auto-normalised to postgresql://)
# DATABASE_URL=

# Admin login
ADMIN_USERNAME=admin
# Provide EITHER a raw password (dev) ...
ADMIN_PASSWORD=admin123
# ... OR a pre-computed hash (prod, preferred). If set, it overrides ADMIN_PASSWORD.
# Generate with:
#   python -c "from werkzeug.security import generate_password_hash as g; print(g('your-password'))"
# ADMIN_PASSWORD_HASH=

# Set to 1 in production (HTTPS only) so the session cookie is marked Secure.
SESSION_COOKIE_SECURE=0
